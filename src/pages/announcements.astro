---
import AnnouncementBoard from '../components/AnnouncementBoard.astro';
import PageShell from '../components/PageShell.astro';
import {
	kioskUpdates,
	posterEvents,
	textAnnouncements,
} from '../data/announcements';
---

<PageShell
	title="Announcements"
	lead="Posters, notices, and updates."
	currentPath="/announcements/"
>
	<AnnouncementBoard
		posterEvents={posterEvents}
		textAnnouncements={textAnnouncements}
		kioskUpdates={kioskUpdates}
	/>
</PageShell>
