---
import Layout from '../layouts/Layout.astro';
import SiteNav from './SiteNav.astro';
import type { BreadcrumbItem } from '../data/shared';

const { title, lead, currentPath = '/' } = Astro.props;
---

<Layout title={title}>
	<div
		aria-hidden="true"
		class="fixed inset-0 -z-10 pointer-events-none bg-[radial-gradient(circle_at_12%_10%,rgba(185,223,191,0.55)_0,rgba(185,223,191,0)_34%),radial-gradient(circle_at_85%_14%,rgba(239,198,111,0.55)_0,rgba(239,198,111,0)_30%),linear-gradient(170deg,#f9f5e8_0%,#f8f0de_48%,#f6e8d3_100%)]"
	>
	</div>
	<div
		class="mx-auto flex w-full max-w-none flex-col gap-4 px-4 pb-12 pt-4 sm:px-5 lg:px-8"
	>
		<SiteNav currentPath={currentPath} />
		<header
			class="w-full rounded-[1.2rem] bg-[linear-gradient(135deg,rgba(34,50,39,0.96),rgba(47,81,56,0.92))] px-5 py-6 text-center text-[#f4f4ef] shadow-[0_18px_45px_rgba(29,39,30,0.16)] sm:px-8 sm:py-10"
		>
			<p
				class="m-0 text-sm font-semibold uppercase tracking-[0.12em] text-[#b9dfbf]"
			>
				Haus 3 Board
			</p>
			<h1
				class="mt-2 font-serif text-4xl font-bold leading-tight tracking-[0.01em] text-[#f4f4ef] sm:text-5xl"
			>
				{title}
			</h1>
			<p
				class="mt-4 block w-full max-w-none text-base leading-7 text-[#edf4e8] sm:text-lg"
			>
				{lead}
			</p>
		</header>
		<main class="flex w-full flex-col gap-4">
			<slot />
		</main>
	</div>
</Layout>
